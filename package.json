{
  "name": "ai-role-player",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "clean": "rimraf dist coverage",
    "build": "pnpm clean && pnpm build:server && pnpm build:client",
    "build:server": "tsup --config tsup.config.ts",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "test": "vitest run",
    "catalog:init": "node --disable-warning=ExperimentalWarning --import tsx scripts/initialize-catalog.ts",
    "catalog:init:prod": "node --disable-warning=ExperimentalWarning dist/server/initialize-catalog.js",
    "database:split": "node --disable-warning=ExperimentalWarning --import tsx scripts/split-database.ts",
    "database:split:prod": "node --disable-warning=ExperimentalWarning dist/server/split-database.js",
    "smoke:realtime": "tsx scripts/smoke-realtime.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@breezystack/lamejs": "^1.2.7",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "antd": "^6.5.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.4",
    "fflate": "^0.8.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ws": "^8.18.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "rimraf": "^6.1.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
